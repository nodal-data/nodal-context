# Live-verification run traces are generated output, not context — keep them local.
evals/runs/*
!evals/runs/.gitkeep

# Verified read-only SQL ("answer keys") for seeds — LOCAL ONLY, never committed.
# SQL goes stale fast and must not be cloneable from the repo; the seed keeps a
# `verified_query_file` pointer, not the query body.
evals/verified/*
!evals/verified/.gitkeep

# Transient dbt bootstrap summary (Stage 0) — not ACF, discard after drafting.
.dbt-findings.json

# Compiled skill snapshots (scripts/compile_skill.py in the tool repo) — build
# artifacts, regenerated from the repo; the repo itself is the source of truth.
dist/

# Python bytecode from the vendored CI tooling (.ci/, eval_harness/, scripts/)
__pycache__/
*.pyc

# macOS
.DS_Store
