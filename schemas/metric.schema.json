{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodaldata.io/acf/metric.schema.json",
  "title": "ACF Metric",
  "type": "object",
  "required": ["metrics"],
  "properties": {
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "definition", "status"],
        "dependentRequired": { "expression": ["grain", "lineage"] },
        "properties": {
          "name": { "type": "string" },
          "definition": { "type": "string" },
          "grain": { "type": "string" },
          "status": { "enum": ["draft", "confirmed"] },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": { "type": "string" },
                "note": { "type": "string" }
              }
            }
          },
          "caveats": { "type": "array", "items": { "type": "string" } },
          "common_filters": { "type": "array", "items": { "type": "string" } },
          "expression": {
            "type": "object",
            "required": ["measure"],
            "properties": {
              "measure": {
                "type": "string",
                "description": "Generic-form aggregation over columns of this metric's lineage models. <placeholders> for parameter values; never a runnable query — FROM lives in lineage, WHERE in mandatory_filters, GROUP BY in allowed_dimensions."
              },
              "mandatory_filters": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["field", "op"],
                  "properties": {
                    "field": { "type": "string" },
                    "op": { "type": "string" },
                    "value": {},
                    "reason": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "allowed_dimensions": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "lineage": { "$ref": "lineage.schema.json" }
        },
        "additionalProperties": false
      }
    }
  }
}
