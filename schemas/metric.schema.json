{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodaldata.io/acf/metric.schema.json",
  "title": "ACF Metric",
  "type": "object",
  "required": ["metrics"],
  "properties": {
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "definition", "status"],
        "properties": {
          "name": { "type": "string" },
          "definition": { "type": "string" },
          "grain": { "type": "string" },
          "status": { "enum": ["draft", "confirmed"] },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": { "type": "string" },
                "note": { "type": "string" }
              }
            }
          },
          "caveats": { "type": "array", "items": { "type": "string" } },
          "common_filters": { "type": "array", "items": { "type": "string" } },
          "lineage": { "$ref": "lineage.schema.json" }
        },
        "additionalProperties": false
      }
    }
  }
}
