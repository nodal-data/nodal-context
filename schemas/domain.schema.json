{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodaldata.io/acf/domain.schema.json",
  "title": "ACF Domain",
  "type": "object",
  "required": ["name", "summary", "status", "grain", "lineage"],
  "properties": {
    "name": { "type": "string" },
    "summary": { "type": "string" },
    "status": { "enum": ["draft", "confirmed"] },
    "owner": { "type": "string" },
    "grain": { "type": "string" },
    "tables": {
      "type": "object",
      "properties": {
        "canonical": { "type": "string" },
        "others": { "type": "array", "items": { "type": "string" } }
      }
    },
    "dashboards": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "owner": { "type": "string" },
          "canonical_question": { "type": "string" }
        }
      }
    },
    "lineage": { "$ref": "lineage.schema.json" }
  },
  "additionalProperties": false
}
